# Apache Configuration for ASH Emran Portfolio
# Place this in the root directory of your web host

# Enable Gzip Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml+rss application/svg+xml
</IfModule>

# Browser Caching
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    
    # CSS and JavaScript
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    
    # Fonts
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/x-font-ttf "access plus 1 year"
    ExpiresByType application/x-font-opentype "access plus 1 year"
    
    # Default
    ExpiresDefault "access plus 2 days"
</IfModule>

# Cache Control Headers
<IfModule mod_headers.c>
    # Remove ETag header
    Header unset ETag
    FileETag None
    
    # Cache control for static resources
    <FilesMatch "\.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|otf|eot)$">
        Header set Cache-Control "max-age=31536000, public"
    </FilesMatch>
    
    # No cache for HTML
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "max-age=3600, must-revalidate"
    </FilesMatch>
    
    # Security Headers
    Header set X-UA-Compatible "IE=edge"
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "no-referrer-when-downgrade"
    
    # HSTS (enable after testing)
    # Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# URL Rewriting for Django
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Remove trailing slashes (Django will add them back with APPEND_SLASH)
    # RewriteCond %{REQUEST_FILENAME} !-d
    # RewriteRule ^(.*)/$ /$1 [L,R=301]
    
    # Redirect HTTP to HTTPS (enable after SSL setup)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
    
    # Redirect www to non-www (customize for your domain)
    # RewriteCond %{HTTP_HOST} ^www\.ashemran\.com$ [NC]
    # RewriteRule ^(.*)$ https://ashemran.shop/$1 [L,R=301]
    
    # Static files and media
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.py/$1 [L]
</IfModule>

# Disable Directory Listing
<IfModule mod_autoindex.c>
    Options -Indexes
</IfModule>

# Prevent access to sensitive files
<FilesMatch "(\.env|\.git|\.htaccess|db\.sqlite3|manage\.py|requirements\.txt|wsgi\.py)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to __pycache__ directories
RewriteRule __pycache__/ - [F,L]

# Allow access to important SEO files
<FilesMatch "(robots\.txt|sitemap\.xml)$">
    Order allow,deny
    Allow from all
</FilesMatch>
